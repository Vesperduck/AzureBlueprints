{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Extension",
      "type": "npm",
      "script": "build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": ["$tsc-watch", "$webpack-builder"]
    },
    {
      "label": "Watch Extension",
      "type": "npm",
      "script": "watch",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "isBackground": true,
      "problemMatcher": ["$tsc-watch", "$webpack-builder"]
    }
  ]
}
