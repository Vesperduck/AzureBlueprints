{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2020",
    "jsx": "react",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node",
    "sourceMap": true,
    "strict": true,
    "noImplicitReturns": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["webview-ui/src"],
  "exclude": ["node_modules", "out"]
}
